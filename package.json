{
  "name": "smartanalyzer",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "concurrently -n be,fe \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:backend": "cd backend && arch -arm64 ./.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && pnpm dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
